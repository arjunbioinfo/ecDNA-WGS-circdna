#!/usr/bin/env bash
# Copy to `env.sh` (git-ignored) and edit the paths for YOUR machine.
# These point at the resources you already have (e.g. your tsd_transfer folder).

# AmpliconArchitect data repository (reference build subfolders inside)
export AA_DATA_REPO="$HOME/Downloads/tsd_transfer/aa_data_repo"

# Directory that contains the Mosek license file named exactly `mosek.lic`
export MOSEK_LICENSE_DIR="$HOME/Downloads/tsd_transfer/mosek"

# Pre-downloaded Singularity/Apptainer container cache
export NXF_SINGULARITY_CACHEDIR="$HOME/Downloads/tsd_transfer/containers"

# Container engine profile: singularity | docker | podman | conda
export PROFILE="singularity"

# Limit Nextflow JVM memory (optional)
export NXF_OPTS='-Xms1g -Xmx4g'
