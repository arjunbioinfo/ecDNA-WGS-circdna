// -----------------------------------------------------------------------------
// Resource / container configuration for nf-core/circdna 1.1.0
// Passed with `-c nextflow.config`.
//
// IMPORTANT (per circdna docs): DO NOT put pipeline *parameters* here.
// Parameters live in params/*.yaml and are passed with `-params-file`.
// `-c` may only set executor, container, and resource settings.
// -----------------------------------------------------------------------------

// Use Singularity by default (recommended for HPC / reproducibility).
// Point NXF_SINGULARITY_CACHEDIR at your pre-downloaded container cache.
singularity {
    enabled    = true
    autoMounts = true
}

// Fallback container engine can be selected with `-profile docker` at runtime.

// Conservative default caps; override per-machine as needed.
// (circdna also exposes --max_cpus/--max_memory/--max_time as params.)
process {
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 2
}
